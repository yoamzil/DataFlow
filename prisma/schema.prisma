generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "sqlite"
    url      = env("DATABASE_URL")
}

model Client {
    id        Int      @id @default(autoincrement())
    idCard    String
    name      String
    phone     String
    date      DateTime
    amount    Float
    duration  Int
    fileId    String
    company   String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
