generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "sqlite"
}

model Admin {
    id             Int     @id @default(autoincrement())
    hashedPassword String
    sessionToken   String? @unique
}

model Client {
    id        Int      @id @default(autoincrement())
    idCard    String
    name      String
    phone     String
    date      DateTime
    amount    Float
    duration  Int
    fileId    String
    company   String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Debt {
    id     Int   @id @default(autoincrement())
    amount Float @default(0)
}
