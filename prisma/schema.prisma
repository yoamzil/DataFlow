generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  date      DateTime
  amount    Float
  fileId    String
  company   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
