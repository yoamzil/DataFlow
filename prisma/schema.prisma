generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Client {
  idCard   String   @id
  name     String
  phone    String
  date     DateTime
  amount   Float
  duration Int
  fileId   String
  company  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
